mments_disabled":null,"view_count":null,"id":"3851339973924500847_3563729185"},{"pk":"3828587176586173789","accessibility_caption":"Photo shared by Elisabetta Ricci on February 08, 2026 tagging \u0040fondazionepaolograssi. May be an image of gown, dress and text.","caption":{"pk":"18127056169558943","text":"Si parte! \u2728\n\nIl nuovo anno mi regala una splendida notizia: \nsono stata ammessa all\u2019Accademia Rodolfo Celletti di Martina Franca, progetto della \u0040fondazionepaolograssi .\n\nPronta a mettermi in gioco, imparare, incontrare nuove voci e lasciarmi sorprendere da ci\u00f2 che verr\u00e0 in questo viaggio intenso e appassionante\ud83c\udfb6"},"audience":null,"carousel_media_count":null,"display_uri":null,"media_type":1,"carousel_media":null,"image_versions2":{"candidates":[{"height":1895,"url":"https:\/\/scontent-mxp1-1.cdninstagram.com\/v\/t51.82787-15\/626280919_18431322898113186_519819084601690222_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=102&ig_cache_key=MzgyODU4NzE3NjU4NjE3Mzc4OQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE0MjF4MTg5NS5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=WZi1ZvAwPboQ7kNvwGcDT-D&_nc_oc=AdkHpfzj7KmaK8rMB_no3G-Krm1y0otflBrGmCd-fqNlsd9qhQcbaMU-SYQsaiV5fDI&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=scontent-mxp1-1.cdninstagram.com&_nc_gid=yvP6cIrP-zvb0Rc8SPZ_BA&_nc_ss=8&oh=00_AfyTUviPOKDLJpdKfDq_n7kPfhPBi653LiNpuqmc63XsLQ&oe=69BE241E","width":1421},{"height":853,"url":"https:\/\/scontent-mxp1-1.cdninstagram.com\/v\/t51.82787-15\/626280919_18431322898113186_519819084601690222_n.jpg?stp=dst-jpg_e35_p640x640_sh0.08_tt6&_nc_cat=102&ig_cache_key=MzgyODU4NzE3NjU4NjE3Mzc4OQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE0MjF4MTg5NS5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=WZi1ZvAwPboQ7kNvwGcDT-D&_nc_oc=AdkHpfzj7KmaK8rMB_no3G-Krm1y0otflBrGmCd-fqNlsd9qhQcbaMU-SYQsaiV5fDI&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=scontent-mxp1-1.cdninstagram.com&_nc_gid=yvP6cIrP-zvb0Rc8SPZ_BA&_nc_ss=8&oh=00_AfzvPe-4YR-162DSHDPOqtus-qiv9XtBBT_fa721x2e0TQ&oe=69BE241E","width":640}]},"code":"DUh38CcCN1d","media_cropping_info":null,"profile_grid_thumbnail_fitting_style":"UNSET","media_overlay_info":null,"preview":null,"product_type":"feed","thumbnails":null,"timeline_pinned_user_ids":[],"upcoming_event":null,"user":{"pk":"3563729185","username":"elisabettariccii","id":"3563729185"},"media_notes":{"items":[]},"like_count":150,"like_and_view_counts_disabled":false,"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":7,"comments_disabled":null,"view_count":null,"id":"3828587176586173789_3563729185"},{"pk":"3827157452831371162","accessibility_caption":null,"caption":{"pk":"18005859929842015","text":"Ivan Bruschi aveva una splendida casa nel centro di Arezzo. La riemp\u00ec di dipinti, sculture, armature, un'incredibile collezione di oggetti d'arte accumulata grazie ai suoi numerosi viaggi. Oggi, la casa Ivan Bruschi \u00e8 un museo, dove Ensemble Sezione Aurea,  grazie al generoso invito di Roberto Pasquini,  ha suonato pi\u00f9 volte. Il 29 marzo,  con Francesca Martini e Elisabetta Ricci, diretta da Roberto Pasquini, Ensemble Sezione Aurea eseguir\u00e0 lo Stabat Mater di Pergolesi. Se volete, vi aspettiamo!"},"audience":null,"carousel_media_count":null,"display_uri":null,"media_type":2,"carousel_media":null,"image_versions2":{"candidates":[{"height":1136,"url":"https:\/\/scontent-mxp1-1.cdninstagram.com\/v\/t51.71878-15\/626610825_25575466178822629_5617767097786738354_n.jpg?stp=dst-jpg_e15_tt6&_nc_cat=107&ig_cache_key=MzgyNzE1NzQ1MjgzMTM3MTE2Mg\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjY0MHgxMTM2LnNkci5DMyJ9&_nc_ohc=jHSa6Gbwal8Q7kNvwFUZob8&_nc_oc=AdmSk84sZFVzJQMKO62seEvEoi6RoCKo206lh-CpRQiZlkxaQojJTEakz2bFf0REjOI&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=scontent-mxp1-1.cdninstagram.com&_nc_gid=yvP6cIrP-zvb0Rc8SPZ_BA&_nc_ss=8&oh=00_Afxo5pcgJpxjSeNWeMVJpxgO7upuc1lHmSO_1-iJy9maJQ&oe=69BE3519","width":640},{"height":1136,"url":"https:\/\/scontent-mxp1-1.cdninstagram.com\/v\/t51.71878-15\/626610825_25575466178822629_5617767097786738354_n.jpg?stp=dst-jpg_e15_tt6&_nc_cat=107&ig_cache_key=MzgyNzE1NzQ1MjgzMTM3MTE2Mg\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjY0MHgxMTM2LnNkci5DMyJ9&_nc_ohc=jHSa6Gbwal8Q7kNvwFUZob8&_nc_oc=AdmSk84sZFVzJQMKO62seEvEoi6RoCKo206lh-CpRQiZlkxaQojJTEakz2bFf0REjOI&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=scontent-mxp1-1.cdninstagram.com&_nc_gid=yvP6cIrP-zvb0Rc8SPZ_BA&_nc_ss=8&oh=00_Afxo5pcgJpxjSeNWeMVJpxgO7upuc1lHmSO_1-iJy9maJQ&oe=69BE3519","width":640}]},"code":"DUcy20bgK-a","media_cropping_info":null,"profile_grid_thumbnail_fitting_style":"UNSET","media_overlay_info":null,"preview":null,"product_type":"clips","thumbnails":null,"timeline_pinned_user_ids":[],"upcoming_event":null,"user":{"pk":"55159258728","username":"ensemblesezioneaurea","id":"55159258728"},"media_notes":{"items":[]},"like_count":56,"like_and_view_counts_disabled":false,"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":1,"comments_disabled":null,"view_count":null,"id":"3827157452831371162_55159258728"},{"pk":"3757935003783664068","accessibility_caption":null,"caption":{"pk":"17900927487310133","text":"\u201cLe nozze di Figaro\u201d di W.A. Mozart \n\nEcco alcuni scatti di questa stupenda produzione de \u201cLe nozze di Figaro\u201d di W.A. Mozart, al Teatro Olimpico di Vicenza per il FestivalVicenzainLirica organizzato da Andrea Castello.\n\n\u00c8 stato bellissimo poter lavorare e apprendere gli insegnamenti del Maestro Alessandro Vitiello e del regista Matteo Anselmi.\n\nCast:\nConte Davide Peroni\nContessa Erica Artina\nFigaro Ignas Melnikas\nSusanna Claudia Mavilia\nCherubino Elisabetta Ricci\nMarcellina Maria Viviani \nBasilio\/Don Curzio Fabio Sabadini \nBartolo Daniel di Prinzio\nAntonio Alberto Spadarotto\n\nDirettore M. Alessandro Vitiello \nRegia M. Matteo Anselmi\n